FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_ADMIN_PHONES
ARG VITE_ADMIN_LOGIN_CODE
ARG VITE_API_URL=http://127.0.0.1:8787
ARG VITE_SITE_URL=http://127.0.0.1:3000

ENV VITE_ADMIN_PHONES=${VITE_ADMIN_PHONES}
ENV VITE_ADMIN_LOGIN_CODE=${VITE_ADMIN_LOGIN_CODE}
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_SITE_URL=${VITE_SITE_URL}

RUN npm run build

FROM nginx:1.27-alpine

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
